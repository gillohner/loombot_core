# loombot secrets & runtime flags
#
# Copy this file to `.env.local` (for local dev with `deno task dev`) or `.env`
# (for Docker Compose). Non-secret operator defaults live in `config.yaml`.

# =====================================================================
# Required
# =====================================================================

# Telegram bot token from @BotFather.
BOT_TOKEN=your_telegram_bot_token_here

# =====================================================================
# Optional runtime flags (apply to both local dev and Docker)
# =====================================================================

# development | production — affects logging noise and a few defaults.
NODE_ENV=development

# 1 to enable verbose debug logging.
DEBUG=0

# debug | info | warn | error
LOG_MIN_LEVEL=info

# 1 = pretty-print logs instead of JSON (useful for `deno task dev`).
LOG_PRETTY=0

# Path to the YAML operator config. Defaults to ./config.yaml
# CONFIG_FILE=./config.yaml

# 1 = webhook mode (production). Default is polling.
WEBHOOK=0

# SQLite path (defaults to ./bot.sqlite for local dev, /data/bot.sqlite in Docker)
# LOCAL_DB_URL=./bot.sqlite

# =====================================================================
# Config-file overrides (optional)
#
# Any value set here patches the loaded `config.yaml` at startup so you
# can swap admin ids or toggle Pubky without editing files. Leave
# commented out to keep whatever is in `config.yaml`.
# =====================================================================

# Comma-separated Telegram user ids — patches `bot.admin_ids`.
# To find your id: DM @userinfobot on Telegram.
# BOT_ADMIN_IDS=123456789,987654321

# 1|true|yes|on — patches `bot.lock_dm_config`. When true, only the
# super-admins listed above can run /config inside their own DMs.
# LOCK_DM_CONFIG=0

# Bot language — patches `bot.language`. Supported: en | de.
# Controls every string the bot code emits (core messages, /config menu,
# service error messages, date formatting). Operator-configured text in
# config.yaml (help.message, welcome.message, triggerword responses, link
# labels, etc.) is NOT translated — it stays whatever the operator wrote.
# BOT_LANGUAGE=en

# =====================================================================
# Pubky (only if any feature publishes events to a homeserver —
# e.g. event_creator / dezentralschweiz profile)
# =====================================================================

# 1|true|yes|on — patches `pubky.enabled`.
# PUBKY_ENABLED=0

# Passphrase for the .pkarr recovery file referenced from config.yaml.
# The file path itself lives in config.yaml under `pubky.recovery_file`
# (or can be overridden below). Not required unless pubky is enabled.
PUBKY_PASSPHRASE=

# Override the recovery-file path from config.yaml. Most useful in Docker
# where the file lives at /data/secrets/operator.pkarr.
# PUBKY_RECOVERY_FILE=./secrets/operator.pkarr

# Telegram chat id of the admin group that approves pending Pubky writes.
# To find a group chat id: add @getidsbot to the group, then remove it.
# PUBKY_APPROVAL_GROUP_CHAT_ID=-1001234567890

# How long a pending write waits for admin approval before it expires.
# PUBKY_APPROVAL_TIMEOUT_HOURS=24

# =====================================================================
# Docker-only
# =====================================================================

# Which profile to copy to /data/config.yaml on first boot. One of:
#   minimal | general-purpose | dezentralschweiz
# Subsequent boots leave the file alone so your edits stick.
# PROFILE=general-purpose

# Base64-encoded .pkarr recovery file, for platforms where file mounts
# are awkward (Umbrel / Start9 / etc). Written to PUBKY_RECOVERY_FILE on
# first boot only; rotating means deleting the volume file first.
# To generate:   base64 -w0 ~/operator.pkarr
# PUBKY_RECOVERY_FILE_B64=
